# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# Accepted values: cloud_api | dualhook | wati. `dualhook` is an alias for
# cloud_api (same Meta Cloud API wire format; Dualhook only configures
# Embedded Signup + Webhook Override on top).
WHATSAPP_PROVIDER=cloud_api
# Optional — Meta Graph API version. Defaults to v25.0 when unset.
WHATSAPP_GRAPH_VERSION=
# Documentation only — not read by code today. Useful to keep alongside the
# other WhatsApp identifiers when operating the Dualhook dashboard.
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Set to "true" to disable HMAC signature verification on webhooks.
# Required for Dualhook Webhook Override: Meta signs with Dualhook's app
# secret which is not exposed to customers. Compensate with a long random
# URL path segment and ideally an IP allowlist for Meta's webhook ranges.
# Leave unset for direct Meta Cloud API.
WHATSAPP_SKIP_SIGNATURE_CHECK=

# WATI (fallback provider — only required when WHATSAPP_PROVIDER=wati)
WATI_API_KEY=
WATI_API_URL=
WATI_ACCESS_TOKEN=

# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
RESPONSE_MODE=generate
CLAUDE_RESPONSE_MODEL=claude-sonnet-4-6

# iCal
ICAL_URL=

# Owner notifications (Phase 5)
# Both channels are optional. Notifications fan out to whichever channel(s) you set.
# WhatsApp recipient + identifies owner for /pause /release /resume /status
# SMTP recipient (optional)
OWNER_EMAIL=
OWNER_PHONE=
OWNER_WHATSAPP_TEMPLATE=owner_notification

# SMTP — only required if OWNER_EMAIL is set
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# SuperControl email integration
# Watching nadine@fosterlabs.dev as the BCC inbox during dev; swap to Jim's
# inbox once permissions land. Gmail IMAP uses the SMTP app password above.
SUPERCONTROL_IMAP_HOST=imap.gmail.com
SUPERCONTROL_IMAP_PORT=993
SUPERCONTROL_IMAP_USER=
SUPERCONTROL_IMAP_PASS=
SUPERCONTROL_IMAP_POLL_MS=30000
# Spacing between back-to-back nudge sends when one poll yields multiple
# unseen emails — avoids Meta template-API rate-limiting.
SUPERCONTROL_DISPATCH_SPACING_MS=3000

# App
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
